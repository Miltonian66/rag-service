# --- Application ---
APP_NAME=rag-service

# --- Database (async DSN; pgvector-enabled Postgres) ---
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# --- Provider selection ---
# embedding_provider: openai | fake
EMBEDDING_PROVIDER=openai
# llm_provider: claude | openai | fake
LLM_PROVIDER=claude

# --- API keys (NEVER commit real values) ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Models ---
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
LLM_MODEL=claude-opus-4-8

# --- Retrieval / generation tuning ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
MAX_TOKENS=1024
